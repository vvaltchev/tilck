#!/usr/bin/env bash
# SPDX-License-Identifier: BSD-2-Clause
#
# Tilck's menuconfig-style reconfiguration entry point.
#
# Defaults to mconf (the Linux-kernel-style UI from the
# host_menuconfig toolchain package). Falls back to ccmake with
# --ccmake.

# Project's root directory
SOURCE_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
MAIN_DIR="$(cd $SOURCE_DIR/.. && pwd)"

usage() {
   cat <<EOF
Usage: $0 [build_dir] [--ccmake]

Arguments:
   build_dir    The CMake build directory to reconfigure.
                Defaults to \$MAIN_DIR/build (= $MAIN_DIR/build).

Options:
   --ccmake     Use the old ccmake UI instead of mconf. Useful as a
                fallback when host_menuconfig isn't installed, or for
                users who prefer ccmake's flat presentation.
   -h, --help   Show this help.
EOF
}

no_mconf_error() {
   echo
   echo "ERROR: host_menuconfig is not installed."
   echo
   echo "The default Tilck configurator uses mconf (the Linux-kernel-style"
   echo "UI) from the host_menuconfig toolchain package. It is optional:"
   echo "Tilck builds and configures fine without it."
   echo
   echo "Install it with one of:"
   echo
   echo "   ./scripts/cmake_run --contrib           # contributor preset"
   echo "                                            # (pulls it in)"
   echo "   ./scripts/build_toolchain -s host_menuconfig"
   echo
   echo "Or fall back to the old ccmake UI:"
   echo
   echo "   $0 $BUILD_DIR --ccmake"
   echo
}

no_ccmake_error() {
   echo
   echo "ERROR: the ccmake tool has not been found on this system."
   echo "Install it on your system before re-running this command."
   echo "Hint: on Ubuntu/Debian systems, its package name is:"
   echo "cmake-curses-gui."
   echo
}

no_build_dir_error() {
   echo
   echo "ERROR: the build directory '$BUILD_DIR' does not exist."
   echo
   echo "Typical case"
   echo "----------------------"
   echo "The build directory does not exist because you haven't run yet"
   echo "the cmake_run script in project's root directory. Run it first."
   echo
   echo "Advanced case"
   echo "----------------------"
   echo "If you're trying to configure a build directory outside of"
   echo "project's root directory, run this script"
   echo "(TILCK_ROOT/scripts/run_config) by passing the build directory"
   echo "as argument."
   echo
}

invalid_build_directory() {
   echo
   echo "ERROR: the build directory '$BUILD_DIR' is NOT a valid CMake"
   echo "build directory. Reason: it does not contain a CMakeCache.txt"
   echo "file."
   echo
   echo "Hint: run the cmake_run script first."
   echo
}

no_sidecar_error() {
   echo
   echo "ERROR: $BUILD_DIR/tilck_options.json is missing."
   echo
   echo "This build directory was created before the tilck_option()"
   echo "migration, or its sidecar was removed. Re-run cmake_run once"
   echo "to regenerate it, then retry:"
   echo
   echo "   $SOURCE_DIR/cmake_run $BUILD_DIR"
   echo
}

# ---------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------

USE_CCMAKE=0
BUILD_DIR=""

while [[ "$#" -gt 0 ]]; do
   case "$1" in
      --ccmake)
         USE_CCMAKE=1
         ;;
      -h|--help)
         usage
         exit 0
         ;;
      -*)
         echo "Unknown option: $1" >&2
         usage >&2
         exit 2
         ;;
      *)
         if [[ -n "$BUILD_DIR" ]]; then
            echo "More than one build dir passed: '$BUILD_DIR' and '$1'" >&2
            exit 2
         fi
         BUILD_DIR="$1"
         ;;
   esac
   shift
done

[[ -z "$BUILD_DIR" ]] && BUILD_DIR="$MAIN_DIR/build"

# ---------------------------------------------------------------------
# Build-dir validation (applies to both mconf and ccmake paths)
# ---------------------------------------------------------------------

if ! [ -d "$BUILD_DIR" ]; then
   no_build_dir_error
   exit 1
fi

if ! [ -f "$BUILD_DIR/CMakeCache.txt" ]; then
   invalid_build_directory
   exit 1
fi

# ---------------------------------------------------------------------
# --ccmake fallback
# ---------------------------------------------------------------------

if [ "$USE_CCMAKE" = 1 ]; then
   if ! command -v ccmake >/dev/null 2>&1; then
      no_ccmake_error
      exit 1
   fi
   exec ccmake "$BUILD_DIR"
fi

# ---------------------------------------------------------------------
# Default path: mconf via host_menuconfig
# ---------------------------------------------------------------------

TCROOT="$MAIN_DIR/toolchain4"

HOST_OS="$(uname -s | tr '[:upper:]' '[:lower:]')"
case "$(uname -m)" in
   x86_64|amd64)   HOST_ARCH="x86_64"  ;;
   aarch64|arm64)  HOST_ARCH="aarch64" ;;
   *)              HOST_ARCH="$(uname -m)" ;;
esac

# /etc/os-release is standard on every Linux distro Tilck supports and
# on FreeBSD >= 13 (but not macOS — which we don't build mconf on
# anyway without extra host_ncurses work; falling through to the "not
# installed" error there is fine).
HOST_DISTRO=""
if [ -f /etc/os-release ]; then
   # shellcheck disable=SC1091
   . /etc/os-release
   HOST_DISTRO="${ID}-${VERSION_ID}"
fi

MCONF_ROOT="$TCROOT/host/$HOST_OS-$HOST_ARCH/$HOST_DISTRO/menuconfig"

if ! [ -d "$MCONF_ROOT" ]; then
   no_mconf_error
   exit 1
fi

# Pick the highest installed version (sort -V handles 1.36.1 correctly).
MCONF_VER="$(ls "$MCONF_ROOT" | sort -V | tail -n 1)"
MCONF_BINDIR="$MCONF_ROOT/$MCONF_VER/install/bin"
MCONF_BIN="$MCONF_BINDIR/mconf"

if ! [ -x "$MCONF_BIN" ]; then
   no_mconf_error
   exit 1
fi

# ---------------------------------------------------------------------
# Sidecar presence
# ---------------------------------------------------------------------

SIDECAR="$BUILD_DIR/tilck_options.json"

if ! [ -f "$SIDECAR" ]; then
   no_sidecar_error
   exit 1
fi

# ---------------------------------------------------------------------
# Generate Kconfig, launch mconf, translate .config → -D args
# ---------------------------------------------------------------------

KCFG_DIR="$BUILD_DIR/kconfig"
GEN="$MAIN_DIR/scripts/dev/configurator/gen_kconfig.py"
APPLY="$MAIN_DIR/scripts/dev/configurator/apply_config.py"

rm -rf "$KCFG_DIR"

if ! python3 "$GEN" --sidecar "$SIDECAR" --out "$KCFG_DIR"; then
   echo "ERROR: gen_kconfig.py failed" >&2
   exit 1
fi

# mconf shells out to lxdialog at runtime for dialog boxes, using a
# HARDCODED relative path: ./scripts/kconfig/lxdialog/lxdialog
# (baked into mconf.c at build time). Create that path under
# $KCFG_DIR as a symlink to the installed binary so the exec
# succeeds from mconf's cwd.
mkdir -p "$KCFG_DIR/scripts/kconfig/lxdialog"
ln -sf "$MCONF_BINDIR/lxdialog" \
      "$KCFG_DIR/scripts/kconfig/lxdialog/lxdialog"

(
   cd "$KCFG_DIR" && "$MCONF_BIN" Kconfig
)
MCONF_EXIT=$?

if [ "$MCONF_EXIT" -ne 0 ]; then
   echo "ERROR: mconf exited with status $MCONF_EXIT" >&2
   exit 1
fi

# No .config written means the user exited without saving — or mconf
# couldn't open a TTY. Either way, nothing to apply.
if ! [ -f "$KCFG_DIR/.config" ]; then
   echo "No changes to apply (mconf did not write .config)."
   exit 0
fi

mapfile -t DARGS < <( \
   python3 "$APPLY" "$KCFG_DIR/.config" "$BUILD_DIR/CMakeCache.txt" \
)

if [ "${#DARGS[@]}" -eq 0 ]; then
   echo "No options changed."
   exit 0
fi

echo
echo "Applying ${#DARGS[@]} option change(s):"
for d in "${DARGS[@]}"; do
   echo "   $d"
done
echo

exec "$MAIN_DIR/scripts/cmake_run" "${DARGS[@]}" "$BUILD_DIR"
